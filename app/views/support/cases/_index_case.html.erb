<tr class="govuk-table__row">
  <td class="govuk-table__cell">
    <%= link_to support_case.organisation, support_case_path(support_case.id), class: "govuk-link--no-visited-state" %>
  </td>

  <td class="govuk-table__cell">
    <strong class="govuk-tag govuk-tag--green">
      <%= support_case.state %>
    </strong>
  </td>

  <td class="govuk-table__cell"><%= support_case.category %></td>
  <td class="govuk-table__cell"><%= support_case.assigned_to %></td>
  <td class="govuk-table__cell"><%= support_case.last_updated %></td>
</tr>